import Layout from '../layouts/Layout.astro';

const aidPrograms = [
  { name: 'Belize Compact（貝里斯協議）', donor: '美國MCC', amount: '125.0', year: '2024簽署（暫緩）', field: '教育（技職訓練80%）、再生能源（20%）；另加政府配套40.6M；2025年8月確認保留', type: 'mcc' },
  { name: 'Climate-Resilient Housing and Infrastructure', donor: 'Adaptation Fund', amount: '23.14', year: '2022–2026', field: '氣候韌性住房、關鍵基礎設施、氣候監測', type: 'multilateral' },
  { name: 'Belize Fund for a Sustainable Future（BFSF）', donor: '多邊/貝里斯政府', amount: '12.5', year: '2022–2026', field: '海洋經濟、生物多樣性、生態保護、海岸發展', type: 'neutral' },
  { name: 'IDA優惠融資額度', donor: '世界銀行IDA', amount: '77.0', year: '2024取得', field: 'IDA會員資格；多領域優惠融資額度（年利率0.75%，還款期30年）', type: 'multilateral' },
  { name: 'Belize Blue Cities and Beyond', donor: '世銀IDA+多方信託', amount: '32.2', year: '2025/1', field: '藍色經濟、城市基礎設施、水質管理、廢棄物處理（San Pedro等）', type: 'multilateral' },
  { name: 'Energy Resilience and Sustainability Project', donor: '世銀IBRD+加拿大', amount: '58.4', year: '2025/2', field: '電力韌性、再生能源整合', type: 'multilateral' },
  { name: 'Cat-DDO（災難遞延提款選擇權）', donor: '世界銀行IDA', amount: '20.0', year: '2025/7', field: '緊急氣候與災難備援流動性', type: 'multilateral' },
  { name: 'Sustainable and Inclusive Urban Development', donor: 'IDB', amount: '1.06', year: '2022–2025', field: '北部市政永續發展', type: 'multilateral' },
  { name: 'Sustainable and Inclusive Belize', donor: 'IDB', amount: '10.0', year: '2023', field: '中小企業、氣候韌性', type: 'multilateral' },
  { name: '貝里斯促進勞動力參與及就業計畫', donor: '台灣ICDF+IDB', amount: '未公開（貸款）', year: '2020–2025', field: '就業服務、技能培訓', type: 'icdf' },
  { name: '貝里斯國家寬頻貸款計畫', donor: '台灣ICDF', amount: '未公開（貸款）', year: '2022–2025', field: '通訊基礎設施', type: 'icdf' },
  { name: '貝里斯醫療影像系統強化計畫', donor: '台灣ICDF', amount: '未公開', year: '2022–2025', field: '醫療設備升級、醫療體系強化', type: 'icdf' },
  { name: '後疫情婦女賦權計畫', donor: '台灣ICDF+OAS', amount: '未公開', year: '2021–2024', field: '婦女就業、創業、金融包容', type: 'icdf' },
  { name: 'BLUE-CAP計畫', donor: 'WTO漁業補貼基金', amount: '未公開', year: '2022–2026', field: '漁業社區、堡礁生態保護', type: 'neutral' },
  { name: 'Plan Belize MTDS 2022–2026（支援項目）', donor: 'UNDP/UN多邊', amount: '未公開（框架）', year: '2022–2026', field: '氣候行動、自然資源管理、藍綠經濟', type: 'neutral' },
];

const rowClass = (type: string) => {
  if (type === 'mcc') return 'bg-amber-50/80';
  if (type === 'icdf') return 'bg-emerald-50/80';
  if (type === 'neutral') return 'bg-beige-50/60';
  return 'bg-white';
};
